{
  "name": "agentbridge",
  "productName": "AgentBridge",
  "version": "0.0.3",
  "description": "멀티 AI 코딩 에이전트 환경에서 context handoff 문제를 해결하는 macOS 데스크탑 앱",
  "main": "./out/main/index.js",
  "author": "h-taek",
  "license": "MIT",
  "homepage": "https://github.com/h-taek/AgentBridge",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/h-taek/AgentBridge.git"
  },
  "bugs": {
    "url": "https://github.com/h-taek/AgentBridge/issues"
  },
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "format": "prettier --write .",
    "lint": "eslint --cache .",
    "typecheck:node": "tsc --noEmit -p tsconfig.node.json --composite false",
    "typecheck:web": "tsc --noEmit -p tsconfig.web.json --composite false",
    "typecheck": "npm run typecheck:node && npm run typecheck:web",
    "start": "unset ELECTRON_RUN_AS_NODE && electron-vite preview",
    "dev": "unset ELECTRON_RUN_AS_NODE && electron-vite dev",
    "build": "npm run typecheck && electron-vite build",
    "postinstall": "electron-builder install-app-deps && node scripts/patch-electron-name.cjs",
    "build:unpack": "npm run build && unset ELECTRON_RUN_AS_NODE && electron-builder --dir",
    "build:mac": "electron-vite build && unset ELECTRON_RUN_AS_NODE && electron-builder --mac",
    "build:mac:external": "bash scripts/build-mac-external.sh"
  },
  "dependencies": {
    "@electron-toolkit/preload": "^3.0.2",
    "@electron-toolkit/utils": "^4.0.0",
    "@homebridge/node-pty-prebuilt-multiarch": "^0.12.0",
    "@xterm/addon-fit": "^0.10.0",
    "@xterm/addon-web-links": "^0.11.0",
    "@xterm/xterm": "^5.5.0",
    "electron-log": "^5.4.0",
    "electron-updater": "^6.8.3",
    "zustand": "^5.0.2"
  },
  "devDependencies": {
    "@electron-toolkit/eslint-config-prettier": "^3.0.0",
    "@electron-toolkit/eslint-config-ts": "^3.1.0",
    "@electron-toolkit/tsconfig": "^2.0.0",
    "@types/node": "^22.19.1",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "electron": "^39.2.6",
    "electron-builder": "^26.0.12",
    "electron-vite": "^5.0.0",
    "eslint": "^9.39.1",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "prettier": "^3.7.4",
    "react": "^19.2.1",
    "react-dom": "^19.2.1",
    "typescript": "^5.9.3",
    "vite": "^7.2.6"
  }
}
